{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PegasusS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::pegasus-backups",
        "arn:aws:s3:::pegasus-backups/*",
        "arn:aws:s3:::pegasus-uploads",
        "arn:aws:s3:::pegasus-uploads/*"
      ]
    },
    {
      "Sid": "PegasusSESSendEmail",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PegasusCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
