# ============================================================
# PEGASUS ERP — Production .env template
# Copy to /var/www/pegasus_erp/.env on the EC2 instance.
# chmod 600 after writing.
# ============================================================

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://erp.tomastech.com
APP_NAME="PEGASUS ERP"
APP_TIMEZONE=Asia/Bangkok

# --- Database (RDS PostgreSQL) ---
DB_HOST=pegasus-erp-prod.xxxxxxxx.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=pegasus_erp
DB_USER=pegasus_admin
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# --- S3 (backups + uploads) ---
AWS_REGION=ap-southeast-1
S3_BACKUP_BUCKET=pegasus-backups
S3_UPLOAD_BUCKET=pegasus-uploads
# Use IAM role attached to EC2 instead of static keys (recommended):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Session / Security ---
SESSION_SECURE_COOKIE=true
SESSION_LIFETIME_MINUTES=120
CSRF_TOKEN_NAME=_csrf_token

# --- Mail (optional SES) ---
MAIL_DRIVER=ses
MAIL_FROM=no-reply@tomastech.com
MAIL_FROM_NAME="PEGASUS ERP"
