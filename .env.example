# Pegasus ERP - environment overrides
# Copy to .env to override. Every value is OPTIONAL: when unset the app falls back
# to the defaults in config/*.php (which already match the Docker stack). The real
# OS environment takes precedence over .env.

# --- Database (config/database.php) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pegasus_erp
DB_USER=postgres
DB_PASS=postgres

# # --- Logging (config/logging.php) ---
# # LOG_DIR=/absolute/path/to/logs   # default: <project>/logs
# LOG_RETENTION_DAYS=7
# LOG_LEVEL=DEBUG                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_TZ=Asia/Bangkok
