# PEGASUS MCP Server — environment variables
# Copy this file to `.env` and adjust values.

# --- PostgreSQL (read-only role recommended) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=pegasus_erp
PG_USER=pegasus_mcp_ro
PG_PASSWORD=change_this_strong_password

# --- PEGASUS HTTP API (used for write operations - Phase 2) ---
PEGASUS_API_BASE=http://localhost:8080
PEGASUS_API_TOKEN=

# --- ERP root (for running system_test / deep_audit via PHP CLI) ---
PEGASUS_ROOT=C:/Users/R.Nozaki/Downloads/Pegasus_ERP_R1
PHP_BIN=php

# --- Logging ---
LOG_LEVEL=INFO
